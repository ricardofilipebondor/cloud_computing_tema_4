generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  processed Boolean  @default(false)
  summary   String?
  fileUrl   String?
  createdAt DateTime @default(now())
}
